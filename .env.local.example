# ─── Resend ────────────────────────────────────────────────────────────────────
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Create an Audience in Resend dashboard → Audiences → Create Audience
# Then copy the Audience ID here
RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Your email — every new signup sends you a notification (optional, delete to disable)
FOUNDER_EMAIL=jmays1x@icloud.com

# ─── Steps to set up ───────────────────────────────────────────────────────────
# 1. Sign up at resend.com (free tier: 3,000 emails/mo, 100/day)
# 2. Add & verify truthcore.ai as a sending domain (takes ~5 min with DNS)
# 3. Create an API key with "Sending access"
# 4. Create an Audience named "Waitlist"
# 5. Copy this file to .env.local and fill in the values
# 6. Add the same env vars in Vercel: Settings → Environment Variables
